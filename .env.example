# PostgreSQL connection string (auto-injected by Railway Postgres plugin)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Public URL of this deployment (no trailing slash)
APP_BASE_URL=https://os-one-cwp-production.up.railway.app

# Comma-separated list of allowed redirect domains.
# REQUIRED for XCC ECP authorization to work. Include your controller's callback hostname.
# ExtremeCloud IQ: apcp.ezcloudx.com
# Leave blank only in development (allows any https URL, which is unsafe in production).
ALLOWED_REDIRECT_DOMAINS=apcp.ezcloudx.com

# Override the default post-acceptance redirect URL (optional)
# If blank, falls back to APP_BASE_URL/success?session=<id>
DEFAULT_SUCCESS_URL=

NODE_ENV=development
