# PostgreSQL connection string (auto-injected by Railway Postgres plugin)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Public URL of this deployment (no trailing slash)
APP_BASE_URL=https://os-one-cwp-production.up.railway.app

# Comma-separated list of allowed redirect domains for ECP callback (server-side).
# Production: apcp.ezcloudx.com (ExtremeCloud IQ relay — cpUseFQDN must be true on XCC)
# Local testing: add the controller IP, e.g. apcp.ezcloudx.com,192.168.100.12
ALLOWED_REDIRECT_DOMAINS=apcp.ezcloudx.com

# Set to "true" to allow HTTPS to private IPs without cert validation (local testing only).
# NEVER set in production — only when XCC sends a raw private IP as hwc_ip (cpUseFQDN=false).
XCC_ALLOW_INSECURE_CALLBACK=false

# XCC External CWP identity and shared secret (must match XCC portal config exactly)
# Identity: the name set in XCC → Network Policy → Captive Portal → Identity
# Shared Secret: the secret set in XCC → Network Policy → Captive Portal → Shared Secret
XCC_IDENTITY=OS-ONE-CWP
XCC_SHARED_SECRET=OSONECWP2026!

# Override the default post-acceptance redirect URL (optional)
# If blank, falls back to APP_BASE_URL/success?session=<id>
DEFAULT_SUCCESS_URL=

NODE_ENV=development
